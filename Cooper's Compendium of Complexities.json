			"entries": [
				"You speak a word that alters the fate of a single creature you can see within 60 feet, changing all possible paths towards a single, inevitable doom.",
				"When you cast this spell, roll {@dice 8d10} and add the amount rolled into a pool. As a bonus action on every turn thereafter, you may roll {@dice 4d10} and add the amount rolled to the same pool as the initial roll.",
				"If at any point the target creature's hit points are equal to or less than the amount in the pool, the creature dies. Once the spell has begun casting, leaving the initial 60-foot range -- including being transported to another plane -- does nothing to halt the spell's effects. The spell continues until you decide to end it, you lose {@status Concentration|XPHB}, the creature is affected by a {@spell Remove Curse} spell of 8th level or higher, or the creature dies.",
				"A creature affected by this spell instinctively understands who has cast the spell and that failing to stop it will result in their death."
			],
			"source": "CoopersCompendiumofComplexities",
			"areaTags": [
				"ST"
			],
			"miscTags": [
				"RO"
			]
		},
