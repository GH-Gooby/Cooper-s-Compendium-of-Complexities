			"str": 6,
			"dex": 16,
			"con": 10,
			"int": 15,
			"wis": 15,
			"cha": 12,
			"passive": 12,
			"cr": "1/4",
			"fluff": {
				"entries": [
					"Lurking in lakes nearby magical villages, one can often find a koibra. A rare mixture of koi fish, cat, and cobra imbued with psychic power, koibra are said to be capable of reading minds and unleashing psychic strikes on enemies. These creatures, though, have been known to be non-hostile, attacking only when necessary, and they seem to enjoy teaming up with creatures of all kinds, so long as they are of sufficient mental capacity.",
					"This last point is particularly important to remember for any adventurer who seeks to tame one, as a koibra hates nothing more than to be commanded by a fool."
				]
			},
			"environment": [
				"coastal",
				"forest"
			],
			"senses": [
				"blindsight 10 ft.",
				"darkvision 60 ft."
			],
			"senseTags": [
				"B",
				"D"
			],
			"languages": [
				"Understands {@language Common}",
				"{@language Mermish|CoopersCompendiumofComplexities}",
				"and {@language Draconic} but can't speak"
			],
			"languageTags": [
				"C",
				"CS",
				"DR"
			],
			"skill": {
				"insight": "+4",
				"investigation": "+4"
			},
			"trait": [
				{
					"name": "Amphibious",
					"entries": [
						"The koibra can breathe both air and water."
					]
				},
				{
					"name": "Limited Telepathy",
					"entries": [
						"The koibra can magically communicate simple ideas, emotions, and images telepathically with any creature within 100 feet of it that can understand a language."
					]
				},
				{
					"name": "Hydrodynamic Reception",
					"entries": [
						"When the koibra is underwater, it can sense all creatures within 60 feet of it by detecting slight currents and vibrations in the liquid. The koibra can identify the size and exact number of creatures around it, but cannot detect anything specific, such as species."
					]
				}
			],
			"traitTags": [
				"Amphibious"
			],
			"variant": [
				{
					"name": "Familiar",
					"entries": [
						"The koibra can serve another creature as a familiar, forming a magic, telepathic bond with that willing companion. While the two are bonded, the companion can sense what the koibra senses as long as they are within 1 mile of each other. While the koibra is within 10 feet of its companion, the companion shares the koibra’s Hydrodynamic Reception trait. At any time and for any reason, the koibra can end its service as a familiar, ending the telepathic bond."
					],
					"type": "variant"
				}
			],
			"familiar": true,
			"action": [
				{
					"name": "Bite",
					"entries": [
						"{@atkr m} {@hit 5} to hit, reach 5 ft., one target {@h}2 ({@damage 1d4}) Piercing damage + 5 ({@damage 2d4}) Poison damage. The target must make a {@dc 10} Constitution saving throw, taking the Poison damage on a failed save, or half as much Poison damage on a successful save."
					]
				},
				{
					"name": "Claw",
					"entries": [
						"{@atkr m} {@hit 5} to hit, reach 5 ft., one target {@h}2 ({@damage 1d6}) Slashing damage."
					]
				},
				{
					"name": "Mental Insight (3/Day)",
					"entries": [
						"The koibra chooses one creature within 30 feet of it that it can see. The target may choose to contest its Charisma (Deception) against the koibra’s Wisdom (Insight) check. If the koibra wins, it magically learns one fact or secret about the creature."
					]
				},
				{
					"name": "Psychic Strike {@recharge 5}",
					"entries": [
						"The koibra stares at a creature that is within 30 feet, emitting psychic energy at the target. The creature must succeed on a {@dc 12} Intelligence saving throw or take 9 ({@damage 3d4 + 2}) Psychic damage and be {@condition Stunned|XPHB} until the start of the koibra’s next turn."
					]
				}
			],
