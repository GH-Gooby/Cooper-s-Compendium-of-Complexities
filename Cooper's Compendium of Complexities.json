			"entries": [
				"Elemental energy surrounds you, swirling in a 10-foot Emanation for the duration. Choose a damage type from the following: Acid, Cold, Fire, Lightning, Poison, and Thunder.",
				"When you cast this spell, and as a bonus action on your turn while it is active, you can force creatures of your choice within the spell's area to make a Constitution saving throw. On a failed save, the creature taks {@damage 1d6} damage of the type chosen. On a successful save, the creature takes half as much damage."
			],
			"source": "CoopersCompendiumofComplexities",
			"components": {
				"v": true,
				"s": true
			},
			"entriesHigherLevel": [
				{
					"type": "entries",
					"name": "Using a Higher-Level Spell Slot",
					"entries": [
						"This spell's damage increases by {@dice 1d6} for each even-numbered spell slot used above 1. This spell's Emanation increases by 5 feet for each odd-numbered spell slot used above 1. So, for example, casting this spell at 5th level would make the Emanation 20 feet, and the damage would be {@dice 3d6}. 6th level would make it 20 feet and {@dice 4d6}, 7th level makes it 25 feet and {@dice 4d6}, and so on."
					]
				}
			],
