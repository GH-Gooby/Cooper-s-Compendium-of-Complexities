			"hp": {
				"formula": "5d8 + 10",
				"average": 38
			},
			"speed": {
				"walk": 40,
				"climb": 30,
				"fly": 25
			},
			"str": 15,
			"dex": 15,
			"con": 14,
			"int": 7,
			"wis": 12,
			"cha": 5,
			"passive": 13,
			"cr": "1",
