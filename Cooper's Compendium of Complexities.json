			"entries": [
				"You channel the colorful omens of the Comet God, Keyanat. When you cast this spell as a Ritual, select a color from the below list. The effects listed under that color are the effects of this spell. If you cast this spell as an Action, a color is chosen at random by the DM.",
				"The effects of this spell end if you begin casting it again.",
				{
					"type": "list",
					"style": "list-hang-notitle",
					"items": [
						{
							"type": "item",
							"name": "Red",
							"entries": [
								"You are granted a vision of the next attack aimed at you or a creature you can touch. The next attack roll aimed at the target of this spell is made at disadvantage."
							]
						},
						{
							"type": "item",
							"name": "Orange",
							"entries": [
								"You peek into the medical future of yourself or a creature you can touch. The next time the target of this spell takes damage, you may use your reaction to immediately heal that creature by {@dice 2d8} Hit Points. This healing takes effect after the damage has already been dealt."
							]
						},
						{
							"type": "item",
							"name": "Yellow",
							"entries": [
								"You seem to know exactly what to say. You or a creature you can touch has advantage on {@skill Deception|XPHB}, {@skill Intimidation|XPHB}, and {@skill Persuasion|XPHB} checks for the next hour."
							]
						},
						{
							"type": "item",
							"name": "Green",
							"entries": [
								"You can feel the life essence around you. For the next hour, you are aware of the exact locations of each Beast, Dragon, Elemental, Fey, Giant, Humanoid, and Plant within 1 mile of yourself."
							]
						},
						{
							"type": "item",
							"name": "Blue",
							"entries": [
								"You know what will try to shake you. For the next hour, you or a creature you can touch is immune to the {@condition Charmed|XPHB} and {@condition Frightened|XPHB} conditions. If the creature was already {@condition Charmed|XPHB} or {@condition Frightened|XPHB}, the condition ends."
							]
						},
						{
							"type": "item",
							"name": "Pink",
							"entries": [
								"You are shown your next opportunity to strike. You or a creature you can touch has advantage on its next Initiative roll."
							]
						}
					]
				}
			],
