					"style": "list-hang-notitle",
					"items": [
						{
							"type": "item",
							"name": "Dismantle",
							"entries": [
								"The swarm starts to dismantle everything in its area. Creatures and objects within the swarm’s area must succeed on a Constitution saving throw or take {@damage 4d8} Force damage, or half as much on a successful save. Constructs and objects take twice as much damage. "
							]
						},
						{
							"type": "item",
							"name": "Relocate",
							"entries": [
								"The swarm latches onto and carries all Medium or smaller creatures and objects within its area to a new location on the ground within 20 feet. The swarm moves with the targets. Unwilling creatures can resist being moved by succeeding on a Strength saving throw. "
							]
						},
						{
							"type": "item",
							"name": "Retroflection",
							"entries": [
								"The constructs project light mimicking the surrounding area until the end of your next turn. While a creature is entirely within the swarm’s area during this time, it has the {@condition Invisible|XPHB} condition."
							]
						}
					]
				}
