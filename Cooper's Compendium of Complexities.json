			"trait": [
				{
					"name": "Blood Rage",
					"entries": [
						"While {@condition Bloodied|XPHB}, the dhampbear has Advantage on attack rolls and when it hits with an attack, it deals an additional 3 ({@damage 1d6}) Necrotic damage."
					]
				},
				{
					"name": "Focused Senses",
					"entries": [
						"The dampbear can see a creature it has dealt damage to in the past 24 hours, even through Total Cover or while it has the {@condition Invisible|XPHB} condition."
					]
				},
				{
					"name": "Spider Climb",
					"entries": [
						"The dhampbear can climb difficult surfaces, including upside down on ceilings, without needing to make an ability check."
					]
				}
			],
			"traitTags": [
				"Spider Climb"
			],
			"action": [
