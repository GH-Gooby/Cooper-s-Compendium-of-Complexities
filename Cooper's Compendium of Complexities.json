			"entries": [
				"You summon an enlightened bear from the ranks of the Ursine Archivists, a revered order dedicated to the preservation and recording of history. He appears in an unoccupied space within range, wearing a modern suit and carrying an ornate ledger.",
				"Upon appearing, the Bear Witness observes and records a significant event unfolding within its sight. The details of this event are inscribed into the bear's ledger with perfect accuracy, later transferred to the eternal archives maintained by their order. Information recorded by the Ursine Archivists is preserved perfectly for all time.",
				"The Bear Witness is immune to all damage and effects. Its only purpose is to witness the event transpiring and will then leave."
			],
			"source": "CoopersCompendiumofComplexities",
			"meta": {
				"ritual": true
			},
			"components": {
				"v": true,
				"s": true,
				"m": {
					"text": "a small piece of honeycomb, enchanted ink, and a bit of parchment, combined worth 100 gold, all of which this spell consumes",
					"consume": true,
					"cost": 10000
				}
			},
			"entriesHigherLevel": [
				{
					"type": "entries",
					"name": "Using a Higher-Level Spell Slot",
					"entries": [
						"When you cast this spell using a spell slot of 5th level or higher, you may request the *Bear Witness* to recount a specific event that any of the *Ursine Archivists* have previously witnessed and recorded. The bear will relay the information in detail, providing insight or clarity into the chosen historical event. Those who hear this recounting innately understand that they are receiving an impartial and absolutely truthful account of the events described."
					]
				}
			],
