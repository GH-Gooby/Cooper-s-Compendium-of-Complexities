					"name": "Multiattack",
					"entries": [
						"The dhampbear makes one Bite attack and two Claw attacks."
					]
				},
				{
					"name": "Bite",
					"entries": [
						"{@atk mw} {@hit 8} to hit, reach 5 ft. {@h}9 ({@damage 1d8 + 5}) Piercing damage + 7 ({@damage 2d6}) Necrotic damage, and the dhampbear regains hit points equal to the Necrotic damage dealt."
					]
				},
				{
					"name": "Claw",
